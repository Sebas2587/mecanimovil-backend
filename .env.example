# ============================================
# MecaniMovil Backend - Variables de Entorno
# ============================================
# Copia este archivo a .env y configura los valores
# NUNCA subas el archivo .env a git

# ============================================
# DJANGO
# ============================================
# Generar una clave secreta segura: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=tu-clave-secreta-super-segura-aqui
DEBUG=False
ALLOWED_HOSTS=.onrender.com,.mecanimovil.com,api.mecanimovil.com

# ============================================
# BASE DE DATOS (PostgreSQL con PostGIS)
# ============================================
# En Render, DATABASE_URL se configura automaticamente
DATABASE_URL=postgis://usuario:password@host:5432/mecanimovil

# Para desarrollo local (alternativa a DATABASE_URL)
# DB_NAME=mecanimovil
# DB_USER=tu_usuario
# DB_PASSWORD=tu_password
# DB_HOST=localhost
# DB_PORT=5432

# ============================================
# REDIS
# ============================================
# En Render, REDIS_URL se configura automaticamente
REDIS_URL=redis://localhost:6379

# Celery (opcional, usa REDIS_URL si no se especifica)
# CELERY_BROKER_URL=redis://localhost:6379/2
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================
# MERCADO PAGO
# ============================================
MERCADOPAGO_MODE=test
MERCADOPAGO_ACCESS_TOKEN=APP_USR-tu-access-token
MERCADOPAGO_WEBHOOK_SECRET=tu-webhook-secret
MERCADOPAGO_PUBLIC_KEY_TEST=TEST-tu-public-key
MERCADOPAGO_PUBLIC_KEY_PROD=APP_USR-tu-public-key-produccion

# ============================================
# CORS
# ============================================
CORS_ALLOWED_ORIGINS=https://mecanimovilapp.com,https://app.mecanimovil.com

# ============================================
# EMAIL (SMTP)
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-app-password
DEFAULT_FROM_EMAIL=noreply@mecanimovil.com

# ============================================
# ALMACENAMIENTO S3 (Opcional - para archivos media)
# ============================================
# AWS_ACCESS_KEY_ID=tu-access-key
# AWS_SECRET_ACCESS_KEY=tu-secret-key
# AWS_STORAGE_BUCKET_NAME=mecanimovil-media
# AWS_S3_REGION_NAME=us-east-1

# ============================================
# SUPERUSUARIO (para build.sh)
# ============================================
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@mecanimovil.com
DJANGO_SUPERUSER_PASSWORD=tu-password-seguro

# ============================================
# SEGURIDAD (Produccion)
# ============================================
SECURE_SSL_REDIRECT=True

# ============================================
# WEBHOOK MercadoPago Preapproval (Suscripciones)
# ============================================
# URL pública del servidor. MercadoPago enviará notificaciones de cobros a:
# {WEBHOOK_BASE_URL}/api/suscripciones/webhook-preapproval/
# En producción Render: https://api.mecanimovil.com
# En desarrollo local: usa ngrok → https://xxxx.ngrok.io
WEBHOOK_BASE_URL=https://api.mecanimovil.com

# === Moneda MercadoPago ===
# ARS=Argentina | CLP=Chile | COP=Colombia
# DEBE coincidir con el país de tu cuenta MP (token)
MERCADOPAGO_CURRENCY=ARS

# MERCADOPAGO_CURRENCY=CLP  # MLC=Chile | MLA=Argentina | MCO=Colombia
# MERCADOPAGO_SITE_ID=MLC
